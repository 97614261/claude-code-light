{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "default capabilities for main window",
  "local": true,
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:webview:default",
    "core:window:default",
    "core:app:default",
    "core:tray:default",
    "core:menu:default",
    "core:image:default",
    "dialog:default",
    "clipboard-manager:allow-write-text",
    "opener:default"
  ]
}
